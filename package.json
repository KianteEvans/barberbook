{
  "name": "barberbook",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "dev:db": "tsx scripts/dev-db.ts",
    "dev:ticker": "tsx scripts/dev-ticker.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "seed": "tsx scripts/dev-seed.ts",
